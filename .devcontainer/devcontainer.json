{
  "name": "Doggo Dev",
  "dockerComposeFile": ["../docker-compose.yml"],
  "service": "app",
  "workspaceFolder": "/workspace",
  // Project-specific environment variables (refreshed on each restart)
  "remoteEnv": {
    "SOME_SECRET_ENV_TOKEN": "${localEnv:SOME_SECRET_ENV_TOKEN}",
  },
  // Default configuration (baked in at container creation)
  "containerEnv": {
    "CLAUDE_CONFIG_DIR": "/home/dev/.claude",
    "POWERLEVEL9K_DISABLE_GITSTATUS": "false",
    // Separate _build and deps from the host to avoid compile lock conflicts
    // and platform mismatch (macOS host vs Linux container).
    "MIX_BUILD_PATH": "/workspace/_build/devcontainer",
    "MIX_DEPS_PATH": "/workspace/deps/devcontainer",
  },
  "initializeCommand": "mkdir -p .claude",
  "remoteUser": "dev",
  "postStartCommand": "sudo /usr/local/bin/init-firewall.sh && sudo bash /workspace/.devcontainer/setup/init-file-protection.sh",
  "waitFor": "postStartCommand",

  // VSCode/Cursor editor configuration
  "customizations": {
    "vscode": {
      "extensions": [
        "jakebecker.elixir-ls",
        "phoenixframework.phoenix",
        "bradlc.vscode-tailwindcss",
        "eamodio.gitlens",
        "github.copilot",
        "editorconfig.editorconfig"
      ],
      "settings": {
        // Elixir settings
        "elixirLS.dialyzerEnabled": false,
        "elixirLS.suggestSpecs": true,
        "elixirLS.signatureHelpEnabled": true,
        "[elixir]": {
          "editor.defaultFormatter": "JakeBecker.elixir-ls",
          "editor.formatOnSave": true,
          "editor.tabSize": 2,
          "editor.insertSpaces": true
        },
        "[heex]": {
          "editor.defaultFormatter": "JakeBecker.elixir-ls",
          "editor.formatOnSave": true,
          "editor.tabSize": 2
        },
        // Phoenix settings
        "tailwindCSS.includeLanguages": {
          "elixir": "html",
          "heex": "html"
        },
        "emmet.includeLanguages": {
          "elixir": "html",
          "heex": "html"
        },
        // Terminal settings
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "zsh": {
            "path": "/bin/zsh"
          }
        }
      }
    }
  },

  // Forward ports to the host
  "forwardPorts": [4000, 5432],
  "portsAttributes": {
    "4000": {
      "label": "Phoenix Server",
      "onAutoForward": "notify"
    },
    "5432": {
      "label": "PostgreSQL",
      "onAutoForward": "silent"
    }
  }
}
